# --- Required secrets (prod) ---
# Use strong random values. Do not commit real secrets.
POSTGRES_PASSWORD=replace_with_strong_postgres_password
LITELLM_KEY=replace_with_strong_litellm_key
MODEL_SWITCHER_TOKEN=replace_with_strong_model_switcher_token
ADMIN_JWT_SECRET=replace_with_strong_admin_jwt_secret

# --- Optional runtime defaults ---
# If omitted, the ops wrapper falls back to qwen-fast.
MODEL_SWITCHER_DEFAULT=qwen-fast

# --- Optional runtime tuning ---
MODEL_SWITCHER_DOCKER_TIMEOUT_SECONDS=30
MODEL_SWITCHER_HEALTH_TIMEOUT_SECONDS=480
MODEL_SWITCHER_POLL_INTERVAL_SECONDS=2
MODEL_SWITCHER_LITELLM_VERIFY_TIMEOUT_SECONDS=90
MODEL_SWITCHER_COMFY_DEFAULT_TTL_MINUTES=45
MODEL_SWITCHER_COMFY_MAX_TTL_MINUTES=90
MODEL_SWITCHER_MODE_POLL_INTERVAL_SECONDS=5

# --- Dynamic model policy ---
MODEL_SWITCHER_DYNAMIC_ALLOW_TRUST_REMOTE_CODE=0
MODEL_SWITCHER_TRUSTED_REPOS=
